model User{
  id           String          @id @default(uuid())
  name         String
  email        String          @unique
  password     String
  role         Role            @default(CUSTOMER)
  activeStatus Status          @default(ACTIVE)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  profile      Profile?
  gearItems    GearItem[]
  rentalOrders RentalOrders[]
  reviews     review[]

  @@map("users")
}

